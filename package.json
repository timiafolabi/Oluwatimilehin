{
  "name": "ai-email-assistant-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker": "tsx workers/runner.ts",
    "db:push": "prisma db push",
    "db:seed": "tsx db/seed.ts",
    "worker:poll": "tsx workers/pollingRunner.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "check:env": "tsx -e \"import('./utils/env.ts')\"",
    "setup:local": "bash scripts/setup-local.sh",
    "test:full": "npm run check:env && npm run build && npm run test",
    "pretest": "npm run typecheck"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "prisma": "^5.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/react-dom": "^18.3.5"
  }
}
