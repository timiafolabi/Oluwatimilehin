DATABASE_URL="postgresql://postgres:postgres@localhost:5432/email_assistant"
APP_URL="http://localhost:3000"
MOCK_MODE="true"
AI_CONFIDENCE_THRESHOLD="0.75"

# Auth/session
SESSION_SECRET="replace-me"
TOKEN_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Gmail OAuth
GOOGLE_CLIENT_ID=""
