GOOGLE_REDIRECT_URI="http://localhost:3000/api/oauth/google/callback"

# Microsoft OAuth
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/oauth/microsoft/callback"

# SMS / Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# AI provider
OPENAI_API_KEY=""
